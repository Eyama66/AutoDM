{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AutoDM Monster Schema",
  "type": "object",
  "required": ["id", "name", "monsterType", "hp", "ac", "attacks"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "monsterType": { "type": "string" },
    "level": { "type": "integer" },
    "challengeRating": { "type": "number" },
    "hp": {
      "type": "object",
      "required": ["current", "max"],
      "properties": {
        "current": { "type": "integer" },
        "max": { "type": "integer" }
      }
    },
    "ac": { "type": "integer" },
    "abilities": {
      "type": "object",
      "properties": {
        "str": { "type": "integer" },
        "dex": { "type": "integer" },
        "con": { "type": "integer" },
        "int": { "type": "integer" },
        "wis": { "type": "integer" },
        "cha": { "type": "integer" }
      }
    },
    "attacks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "attackBonus", "damageDice"],
        "properties": {
          "name": { "type": "string" },
          "attackBonus": { "type": "integer" },
          "damageDice": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    }
  }
}
